<Application x:Class="PulseWidget.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackground" Color="#F312161D" po:Freeze="False" />
        <SolidColorBrush x:Key="CardBackground" Color="#FF1A2029" po:Freeze="False" />
        <SolidColorBrush x:Key="MutedText" Color="#FF83909F" po:Freeze="False" />
        <SolidColorBrush x:Key="PrimaryText" Color="#FFF5F8FA" po:Freeze="False" />
        <SolidColorBrush x:Key="CpuAccent" Color="#FF66E3A4" po:Freeze="False" />
        <SolidColorBrush x:Key="GpuAccent" Color="#FF62A7FF" po:Freeze="False" />

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Width" Value="31" />
            <Setter Property="Height" Value="27" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Foreground" Value="{StaticResource MutedText}" />
            <Setter Property="Background" Value="#00FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Segoe UI Semibold" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF252D38" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
