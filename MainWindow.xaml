<Window x:Class="PulseWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PulseWidget.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Pulse Widget"
        Icon="Assets/PulseWidget.ico"
        Width="390"
        Height="650"
        MinWidth="360"
        MinHeight="590"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{StaticResource WindowBackground}"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            CornerRadius="22"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border
            Padding="18"
            CornerRadius="22"
            Background="{StaticResource WindowBackground}"
            BorderBrush="#FF2A333F"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="BeforeUsageSpacingRow" Height="10" />
                <RowDefinition x:Name="UsageChartRow" Height="*" />
                <RowDefinition x:Name="BetweenChartsSpacingRow" Height="10" />
                <RowDefinition x:Name="TemperatureChartRow" Height="*" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      Background="Transparent"
                      Cursor="SizeAll"
                      PreviewMouseLeftButtonDown="DragArea_PreviewMouseLeftButtonDown"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="27" Height="27" Margin="0,0,9,0">
                            <Canvas Width="32" Height="32">
                                <Path Fill="#FF62A7FF" Data="M17,2 C22,5 25,10 25,16 L20,21 17,28 14,22 9,18 3,17 10,12 C11,7 13,4 17,2 Z" />
                                <Ellipse Width="7" Height="7" Canvas.Left="15" Canvas.Top="9" Fill="#FF12161D" Stroke="#FF66E3A4" StrokeThickness="1.5" />
                                <Path Fill="#FF66E3A4" Data="M9,20 L5,27 12,23 Z" />
                            </Canvas>
                        </Viewbox>
                        <StackPanel>
                            <TextBlock Text="PULSE" FontSize="15" FontFamily="Segoe UI Semibold" />
                            <TextBlock Text="SYSTEM MONITOR" FontSize="9" Foreground="{StaticResource MutedText}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="PinButton" Style="{StaticResource ChromeButton}" Content="PIN" Click="PinButton_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button x:Name="CompactButton" Style="{StaticResource ChromeButton}" Content="CMP" Click="CompactButton_Click" ToolTip="Alternar modo compacto" shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button Style="{StaticResource ChromeButton}" Content="SET" Click="SettingsButton_Click" ToolTip="Configuracoes" shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button Style="{StaticResource ChromeButton}" Content="_" Click="HideButton_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button x:Name="MaximizeButton" Style="{StaticResource ChromeButton}" Click="MaximizeButton_Click" ToolTip="Maximizar ou restaurar" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Width="10" Height="10" Stretch="Fill" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.2">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Data" Value="M 1,1 L 9,1 9,9 1,9 Z" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                            <Setter Property="Data" Value="M 3,1 L 9,1 9,7 M 1,3 L 7,3 7,9 1,9 Z" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Button>
                    <Button Style="{StaticResource ChromeButton}" Content="X" Click="HideButton_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="CPU" Foreground="{StaticResource CpuAccent}" FontFamily="Segoe UI Semibold" FontSize="11" />
                            <TextBlock x:Name="CpuTemperatureText" Text="-- C" Foreground="{StaticResource MutedText}" HorizontalAlignment="Right" />
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,3">
                            <TextBlock x:Name="CpuUsageText" Text="--" FontSize="31" FontFamily="Segoe UI Semibold" />
                            <TextBlock Text="%" FontSize="14" Foreground="{StaticResource MutedText}" VerticalAlignment="Bottom" Margin="3,0,0,5" />
                        </StackPanel>
                        <TextBlock x:Name="CpuDetailText" Text="-- GHz  /  -- W" FontSize="10" Foreground="{StaticResource MutedText}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="GPU" Foreground="{StaticResource GpuAccent}" FontFamily="Segoe UI Semibold" FontSize="11" />
                            <TextBlock x:Name="GpuTemperatureText" Text="-- C" Foreground="{StaticResource MutedText}" HorizontalAlignment="Right" />
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,3">
                            <TextBlock x:Name="GpuUsageText" Text="--" FontSize="31" FontFamily="Segoe UI Semibold" />
                            <TextBlock Text="%" FontSize="14" Foreground="{StaticResource MutedText}" VerticalAlignment="Bottom" Margin="3,0,0,5" />
                        </StackPanel>
                        <TextBlock x:Name="GpuDetailText" Text="-- GHz  /  -- W" FontSize="10" Foreground="{StaticResource MutedText}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="4" Style="{StaticResource Card}" Padding="14,11">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="MEMORIA" FontSize="10" Foreground="{StaticResource MutedText}" />
                        <TextBlock x:Name="MemoryUsageText" Text="--%" FontSize="19" FontFamily="Segoe UI Semibold" />
                    </StackPanel>
                    <ProgressBar x:Name="MemoryProgress"
                                 Grid.Column="1"
                                 Height="6"
                                 Margin="18,0"
                                 Minimum="0"
                                 Maximum="100"
                                 Background="#FF303946"
                                 Foreground="#FFB38BFA"
                                 BorderThickness="0" />
                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                        <TextBlock Text="RAM" FontSize="10" Foreground="{StaticResource MutedText}" HorizontalAlignment="Right" />
                        <TextBlock x:Name="MemoryDetailText" Text="-- / -- GB" FontSize="12" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="6" Style="{StaticResource Card}" Padding="14,11">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock x:Name="UsageChartTitle" Text="USO / ULTIMOS 2 MIN" FontSize="10" Foreground="{StaticResource MutedText}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="CPU " FontSize="9" Foreground="{StaticResource MutedText}" />
                            <TextBlock x:Name="CpuUsageLegendValue" Text="--%" FontSize="10" Foreground="{StaticResource CpuAccent}" Margin="0,0,10,0" />
                            <TextBlock Text="GPU " FontSize="9" Foreground="{StaticResource MutedText}" />
                            <TextBlock x:Name="GpuUsageLegendValue" Text="--%" FontSize="10" Foreground="{StaticResource GpuAccent}" />
                        </StackPanel>
                    </DockPanel>
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <controls:LineChart x:Name="UsageChart"
                                            MinHeight="60"
                                            PrimaryStroke="{StaticResource CpuAccent}"
                                            SecondaryStroke="{StaticResource GpuAccent}"
                                            PrimaryThreshold="90"
                                            SecondaryThreshold="90"
                                            Maximum="100" />
                        <TextBlock x:Name="UsageStatsText" Grid.Row="1" Margin="0,5,0,0" FontSize="9" Foreground="{StaticResource MutedText}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="8" Style="{StaticResource Card}" Padding="14,11">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock x:Name="TemperatureChartTitle" Text="TEMPERATURA / ULTIMOS 2 MIN" FontSize="10" Foreground="{StaticResource MutedText}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="CPU " FontSize="9" Foreground="{StaticResource MutedText}" />
                            <TextBlock x:Name="CpuTemperatureLegendValue" Text="-- C" FontSize="10" Foreground="#FFA8F07A" Margin="0,0,10,0" />
                            <TextBlock Text="GPU " FontSize="9" Foreground="{StaticResource MutedText}" />
                            <TextBlock x:Name="GpuTemperatureLegendValue" Text="-- C" FontSize="10" Foreground="#FF73E1F4" />
                        </StackPanel>
                    </DockPanel>
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <controls:LineChart x:Name="TemperatureChart"
                                            MinHeight="60"
                                            PrimaryStroke="#FFA8F07A"
                                            SecondaryStroke="#FF73E1F4"
                                            Dashed="True"
                                            Maximum="110" />
                        <TextBlock x:Name="TemperatureStatsText" Grid.Row="1" Margin="0,5,0,0" FontSize="9" Foreground="{StaticResource MutedText}" />
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="StatusIndicator" Width="7" Height="7" Fill="#FF66E3A4" VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Grid.Column="1"
                           Text="Iniciando sensores..."
                           Margin="8,0"
                           FontSize="10"
                           Foreground="{StaticResource MutedText}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="IntervalText" Grid.Column="2" Text="1 s" FontSize="10" Foreground="{StaticResource MutedText}" />
            </Grid>
        </Grid>
    </Border>
</Window>
