<Window x:Class="PulseWidget.Views.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diagnostico do Pulse Widget"
        Icon="/Assets/PulseWidget.ico"
        Width="760"
        Height="560"
        MinWidth="560"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#FF12161D"
        Foreground="#FFF5F8FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="DIAGNOSTICO DE SENSORES" FontSize="17" FontFamily="Segoe UI Semibold" />
            <TextBlock Text="Identificadores, tipos e valores informados pelo LibreHardwareMonitor" Foreground="#FF83909F" />
        </StackPanel>
        <TextBox x:Name="ReportTextBox"
                 Grid.Row="2"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Cascadia Mono, Consolas"
                 FontSize="11"
                 Background="#FF0D1117"
                 Foreground="#FFD7E0E8"
                 BorderBrush="#FF2A333F" />
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Copiar" Width="90" Height="32" Margin="0,0,10,0" Click="CopyButton_Click" />
            <Button Content="Exportar..." Width="100" Height="32" Click="ExportButton_Click" />
        </StackPanel>
    </Grid>
</Window>
