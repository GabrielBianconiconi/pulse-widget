<Window x:Class="PulseWidget.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuracoes do Pulse Widget"
        Icon="/Assets/PulseWidget.ico"
        Width="430"
        Height="680"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF12161D"
        Foreground="#FFF5F8FA">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="22" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="CONFIGURACOES" FontSize="18" FontFamily="Segoe UI Semibold" />
            <TextBlock Text="Ajustes aplicados sem reiniciar o monitor" Margin="0,4,0,0" Foreground="#FF83909F" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="155" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Intervalo de atualizacao" FontFamily="Segoe UI Semibold" />
                <TextBlock Text="Intervalos maiores reduzem o uso de CPU" FontSize="11" Foreground="#FF83909F" />
            </StackPanel>
            <ComboBox x:Name="IntervalComboBox" Grid.Column="1" Height="32" VerticalContentAlignment="Center">
                <ComboBoxItem Content="1 segundo" Tag="1000" />
                <ComboBoxItem Content="2 segundos" Tag="2000" />
                <ComboBoxItem Content="5 segundos" Tag="5000" />
            </ComboBox>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="155" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Opacidade" FontFamily="Segoe UI Semibold" />
                <TextBlock Text="Transparencia de toda a janela" FontSize="11" Foreground="#FF83909F" />
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock x:Name="OpacityValueText" HorizontalAlignment="Right" Foreground="#FF66E3A4" />
                <Slider x:Name="OpacitySlider" Minimum="55" Maximum="100" TickFrequency="5" ValueChanged="OpacitySlider_ValueChanged" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="155" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Historico dos graficos" FontFamily="Segoe UI Semibold" />
                <TextBlock Text="Janela de tempo mantida em memoria" FontSize="11" Foreground="#FF83909F" />
            </StackPanel>
            <ComboBox x:Name="HistoryComboBox" Grid.Column="1" Height="32" VerticalContentAlignment="Center">
                <ComboBoxItem Content="2 minutos" Tag="2" />
                <ComboBoxItem Content="5 minutos" Tag="5" />
                <ComboBoxItem Content="15 minutos" Tag="15" />
                <ComboBoxItem Content="30 minutos" Tag="30" />
            </ComboBox>
            <StackPanel Grid.Row="2">
                <TextBlock Text="GPU monitorada" FontFamily="Segoe UI Semibold" />
                <TextBlock Text="Auto permanece na mesma GPU durante a sessao" FontSize="11" Foreground="#FF83909F" />
            </StackPanel>
            <ComboBox x:Name="GpuComboBox" Grid.Row="2" Grid.Column="1" Height="32" DisplayMemberPath="Name" VerticalContentAlignment="Center" />
            <StackPanel Grid.Row="4">
                <TextBlock Text="Tema" FontFamily="Segoe UI Semibold" />
                <TextBlock Text="Paleta aplicada ao dashboard" FontSize="11" Foreground="#FF83909F" />
            </StackPanel>
            <ComboBox x:Name="ThemeComboBox" Grid.Row="4" Grid.Column="1" Height="32" VerticalContentAlignment="Center">
                <ComboBoxItem Content="Escuro" Tag="Dark" />
                <ComboBoxItem Content="Grafite" Tag="Graphite" />
                <ComboBoxItem Content="Claro" Tag="Light" />
            </ComboBox>
        </Grid>

        <CheckBox x:Name="AlwaysOnTopCheckBox" Grid.Row="8" Content="Manter sempre no topo" FontFamily="Segoe UI Semibold" />

        <CheckBox x:Name="ClickThroughCheckBox" Grid.Row="10" Content="Ignorar cliques do mouse" FontFamily="Segoe UI Semibold" />

        <CheckBox x:Name="CompactModeCheckBox" Grid.Row="12" Content="Usar modo compacto" FontFamily="Segoe UI Semibold" />

        <CheckBox x:Name="StartupCheckBox" Grid.Row="14" Content="Iniciar com o Windows" FontFamily="Segoe UI Semibold" />

        <Border Grid.Row="15" Margin="0,14,0,14" Padding="14" CornerRadius="10" Background="#FF1A2029" VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <CheckBox x:Name="AlertsEnabledCheckBox" Content="Alertas de temperatura" FontFamily="Segoe UI Semibold" />
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="65" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="65" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="CPU limite" VerticalAlignment="Center" Foreground="#FF83909F" />
                    <TextBox x:Name="CpuThresholdTextBox" Grid.Column="1" Height="28" VerticalContentAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="GPU limite" VerticalAlignment="Center" Foreground="#FF83909F" />
                    <TextBox x:Name="GpuThresholdTextBox" Grid.Column="4" Height="28" VerticalContentAlignment="Center" />
                </Grid>
                <StackPanel Grid.Row="4">
                    <CheckBox x:Name="GpuFirstCheckBox" Content="Mostrar GPU antes da CPU" Margin="0,0,0,8" />
                    <WrapPanel>
                        <CheckBox x:Name="ShowVramCheckBox" Content="VRAM" Margin="0,0,14,6" />
                        <CheckBox x:Name="ShowStorageCheckBox" Content="SSD" Margin="0,0,14,6" />
                        <CheckBox x:Name="ShowFansCheckBox" Content="Fans" Margin="0,0,14,6" />
                        <CheckBox x:Name="ShowNetworkCheckBox" Content="Rede" Margin="0,0,0,6" />
                        <CheckBox x:Name="RtssEnabledCheckBox" Content="FPS via RTSS" Margin="14,0,0,6" />
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="16" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="92" Height="34" Margin="0,0,10,0" IsCancel="True" />
            <Button Content="Aplicar" Width="92" Height="34" IsDefault="True" Click="ApplyButton_Click" />
        </StackPanel>
    </Grid>
</Window>
